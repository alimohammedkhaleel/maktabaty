# ⚙️ متغيرات البيئة - حول القيم حسب إعدادات جهازك

# ========== إعدادات الخادم ==========
PORT=3001

# ========== إعدادات قاعدة البيانات MySQL ==========
DB_HOST=localhost           # عنوان الخادم (عادة localhost)
DB_USER=root               # اسم المستخدم (عادة root)
DB_PASSWORD=               # كلمة المرور (اتركها فارغة إذا لم تكن هناك)
DB_NAME=library_db         # اسم قاعدة البيانات
DB_PORT=3306              # منفذ MySQL الافتراضي

# ========== إعدادات الأمان ==========
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRE=7d             # صلاحية التوكن

# ========== إعدادات البيئة ==========
ENVIRONMENT=development   # development أو production

# ========== ملاحظات مهمة ==========
# 1. غير JWT_SECRET قبل الإنتاج إلى قيمة قوية
# 2. تأكد من تشغيل MySQL قبل بدء الخادم
# 3. في الإنتاج، استخدم متغيرات بيئة آمنة
# 4. لا تشارك هذا الملف مع أحد (أضفه إلى .gitignore)
