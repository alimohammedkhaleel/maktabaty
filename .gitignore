# Dependencies
node_modules/
client/my-react-app/node_modules/
server/node_modules/

# Environment variables
.env
.env.local
.env.production
server/.env

# Build outputs
client/my-react-app/dist/
client/my-react-app/build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
server/server-output.log

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Uploads (optional - you may want to keep these)
server/uploads/*.pdf
server/uploads/*.jpg
server/uploads/*.png

# Keep uploads directory structure
!server/uploads/.gitkeep
